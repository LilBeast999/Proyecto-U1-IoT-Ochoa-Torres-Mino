    {
        "id": "8f08438258250934",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "parsear respuesta",
        "func": "// === F4.3/4.4 — Mostrar respuesta NL del LLM ===\nlet raw = msg.payload && msg.payload.response;\nlet texto = (raw || '').toString().trim();\n\nif (!texto) {\n    texto = 'El asistente no respondió. ¿Está activo Ollama?';\n}\n\nlet pregunta = msg.pregunta || '';\n\n// Salida 1 -> ui_text (mostrar en el dashboard)\nlet out_ui = { payload: texto };\n\n// Salida 2 -> mqtt out (smarthome/equipoXX/llm/respuesta)\nlet out_mqtt = {\n    topic: 'smarthome/equipoXX/llm/respuesta',\n    payload: JSON.stringify({ pregunta: pregunta, respuesta: texto, ts: Date.now() })\n};\n\nreturn [out_ui, out_mqtt];\n",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
