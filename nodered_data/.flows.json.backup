        "sep": ",",
        "hdrin": "",
        "hdrout": "all",
        "multi": "one",
        "ret": "\\r\\n",
        "temp": "timestamp,temperatura,humedad,gas,estado_alerta",
        "skip": "0",
        "strings": true,
        "include_empty_strings": "",
        "include_null_values": "",
