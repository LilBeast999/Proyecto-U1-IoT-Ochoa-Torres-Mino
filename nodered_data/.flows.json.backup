    {
        "id": "a1b2agentedisp",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "dispatch agente",
        "func": "let a = msg.payload || {};\nlet tipo = a.tipo;\nlet out = [null, null, null, null];  // [mqtt, telegram, influx, respuesta]\nconst TOPICOS = { led:'smarthome/equipoXX/control/led', buzzer:'smarthome/equipoXX/control/buzzer', luz:'smarthome/equipoXX/luz_manual' };\nif (tipo === 'activar_actuador') {\n    let t = TOPICOS[a.actuador];\n    if (t) out[0] = { topic: t, payload: (a.estado ? '1' : '0') };\n} else if (tipo === 'ajustar_umbral') {\n    flow.set('umbral_' + a.variable, a.valor);\n    out[0] = { topic: 'smarthome/equipoXX/umbral/' + a.variable, payload: String(a.valor) };\n} else if (tipo === 'enviar_notificacion') {\n    out[1] = { payload: { chat_id: '1455813427', text: '[agente] ' + (a.texto || a.mensaje || 'evento') } };\n}\nout[2] = { measurement: 'decisiones', payload: { tipo: String(tipo||''), detalle: JSON.stringify(a), razonamiento: String(a.razonamiento||'') } };\nout[3] = Object.assign({}, msg, { payload: { ok: true, tipo: tipo } });\nreturn out;",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
