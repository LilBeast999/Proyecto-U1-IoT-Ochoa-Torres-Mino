    {
        "id": "113d46af4798182a",
        "type": "ui_text_input",
        "z": "cba3b38867a78e6d",
        "name": "entrada_nl",
        "label": "preguntale a tu casita",
        "tooltip": "",
        "group": "d6d11e5f510da65c",
        "order": 16,
        "width": 0,
        "height": 0,
        "passthru": true,
