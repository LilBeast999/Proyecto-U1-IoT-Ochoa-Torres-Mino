    {
        "id": "25d6ce4d2b28971c",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "Construir consulta NL",
        "func": "// === F4.2 — Consulta en lenguaje natural al LLM ===\n// Entrada: msg.payload = texto que el usuario escribió en el text input\n\nlet pregunta = (msg.payload || '').toString().trim();\n\n// Si el campo está vacío, no dispares el LLM\nif (!pregunta) {\n    node.warn('Pregunta vacía, no se envía al LLM');\n    return null;\n}\n\n// Mismo contexto de sensores que usa F3 (flow.estado / flow.persona)\nlet e = flow.get('estado') || {};\nlet persona = flow.get('persona') || 'ninguna';\nlet hora = new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });\n\nlet estado = `temperatura=${e.temperatura ?? 'NA'}C, humedad=${e.humedad ?? 'NA'}%, ` +\n    `gas=${e.gas ?? 'NA'} (rango 0-4095, critico>2500), microfono=${e.microfono ?? 'NA'}, ` +\n    `persona=${persona}, hora=${hora}`;\n\nlet prompt = `Eres el asistente de una casa inteligente. Responde la pregunta del usuario de forma breve y clara, en español, basandote UNICAMENTE en el estado actual de los sensores. Si la pregunta no tiene relacion con la casa, dilo amablemente.\n\nEstado actual del hogar: ${estado}.\n\nPregunta del usuario: ${pregunta}\n\nRespuesta (2 o 3 frases, en texto plano, sin JSON):`;\n\n// Guardamos la pregunta para mostrarla junto a la respuesta más adelante (4.4)\nmsg.pregunta = pregunta;\n\nmsg.payload = {\n    model: 'llama3.2:3b',\n    prompt: prompt,\n    stream: false,\n    keep_alive: -1,\n    options: { temperature: 0.3, num_predict: 200 }\n};\nmsg.headers = { 'Content-Type': 'application/json' };\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 1880,
        "wires": [
            [
                "f700cf38116077a7"
            ]
        ]
    },
