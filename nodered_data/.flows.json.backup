        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "parsear decisión",
        "func": "let raw = msg.payload && msg.payload.response;\nlet dec;\ntry {\n    dec = JSON.parse(raw);\n    // valida que el LLM devolvio algo usable\n    if (typeof dec.activar_led === 'undefined' || typeof dec.activar_buzzer === 'undefined'\n        || !['normal','advertencia','critico'].includes(dec.nivel_alerta)) {\n        throw new Error('respuesta incompleta');\n    }\n} catch (err) {\n    // FALLBACK: solo si el LLM no responde o el JSON es invalido\n    node.warn('LLM no disponible/JSON invalido, fallback por regla: ' + raw);\n    let e = flow.get('estado') || {};\n    let gas = Number(e.gas) || 0, temp = Number(e.temperatura) || 0, hum = Number(e.humedad) || 0;\n    let critico = (gas > 2500) || (temp > 40), adv = (gas > 1800) || (temp > 24) || (hum > 70);\n    dec = {\n        nivel_alerta: critico ? 'critico' : (adv ? 'advertencia' : 'normal'),\n        activar_led: critico || adv, activar_buzzer: critico,\n        mensaje_alerta: 'Decision por regla (LLM no disponible)', razonamiento: 'fallback'\n    };\n}\n\n// Gemelo: el agente actualiza resumen_llm cada ciclo\nlet gg = global.get('gemelo') || {};\ngg.resumen_llm = {nivel: dec.nivel_alerta, mensaje: dec.mensaje_alerta, razonamiento: dec.razonamiento, hora: new Date().toISOString()};\nglobal.set('gemelo', gg);\n\nlet luz      = { topic: 'smarthome/equipoXX/luz_manual',     payload: dec.activar_led    ? '1' : '0' };\nlet buz      = { topic: 'smarthome/equipoXX/control/buzzer', payload: dec.activar_buzzer ? '1' : '0' };\nlet decision = { topic: 'smarthome/equipoXX/llm/decision',   payload: JSON.stringify(dec) };\nlet dbg      = { payload: dec };\nreturn [luz, buz, decision, dbg];\n",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
