    {
        "id": "a1b2gemeloupd001",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "actualizar gemelo",
        "func": "// Gemelo digital: estado en vivo + historial (60 registros a 1/min)\nlet g = global.get('gemelo') || {estado:{},historial:{temperatura:[],humedad:[],gas:[]},prediccion:{},resumen_llm:'',actualizado:null,_lastHist:0};\nlet p = msg.payload || {};\nlet now = Date.now();\ng.estado = {temperatura:Number(p.temperatura), humedad:Number(p.humedad), gas:Number(p.gas)};\ng.persona = flow.get('persona') || 'ninguna';\ng.actualizado = new Date(now).toISOString();\nif (now - (g._lastHist||0) >= 60000) {\n    g._lastHist = now;\n    ['temperatura','humedad','gas'].forEach(function(k){\n        let v = g.estado[k];\n        if (!isNaN(v)) { g.historial[k].push({t:g.actualizado, v:v}); if (g.historial[k].length > 60) g.historial[k].shift(); }\n    });\n}\nglobal.set('gemelo', g);\nreturn null;",
        "outputs": 0,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 1380,
