    {
        "id": "ce9c60e3f7b45672",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "Construir prompt",
        "func": "let e = flow.get('estado') || {};\nlet persona = flow.get('persona') || 'ninguna';\nlet hora = new Date().toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});\n\nlet estado = `temperatura=${e.temperatura ?? 'NA'}C, humedad=${e.humedad ?? 'NA'}%, ` +\n             `gas=${e.gas ?? 'NA'} (rango 0-4095), microfono=${e.microfono ?? 'NA'}, ` +\n             `persona=${persona}, hora=${hora}`;\n\nlet prompt = `Eres el sistema de control de una casa inteligente. Clasifica el nivel de alerta comparando los numeros de gas, temperatura y humedad.\n\nREGLAS (basta que UNA condicion se cumpla para subir de nivel):\n- critico: gas mayor que 2500 O temperatura mayor que 40\n- advertencia: (gas mayor que 1800 O temperatura mayor que 24 O humedad mayor que 70) y no critico\n- normal: cualquier otro caso\n\nEJEMPLOS:\n- gas=3200 => critico (gas > 2500)\n- temperatura=45 => critico (temperatura > 40)\n- gas=2000 => advertencia (gas > 1800 y no critico)\n- temperatura=30 => advertencia (temperatura > 24)\n- humedad=75 => advertencia (humedad > 70)\n- gas=1500, temperatura=22, humedad=50 => normal\n\nACCIONES: critico => activar_led=true, activar_buzzer=true. advertencia => activar_led=true, activar_buzzer=false. normal => ambos false.\n\nEstado actual: ${estado}.\n\nResponde UNICAMENTE en JSON, sin texto adicional:\n{\"nivel_alerta\":\"...\",\"activar_led\":false,\"activar_buzzer\":false,\"mensaje_alerta\":\"texto breve\",\"razonamiento\":\"explica que regla aplicaste\"}`;\n\nmsg.payload = {\n    model: 'llama3.2:3b', prompt: prompt, stream: false, format: 'json',\n    keep_alive: -1, options: { temperature: 0, num_predict: 200 }\n};\nmsg.headers = { 'Content-Type': 'application/json' };\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 1560,
        "wires": [
            [
                "2c5efe22f51c212a"
            ]
        ]
    },
