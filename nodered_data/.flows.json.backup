    {
        "id": "a1b2predfunc001",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "gemelo <- prediccion",
        "func": "// topic: smarthome/equipoXX/prediccion/<field>\nlet parts = msg.topic.split('/');\nlet field = parts[parts.length-1];\nlet data = msg.payload;\nif (typeof data === 'string') { try { data = JSON.parse(data); } catch(e){ return null; } }\nlet g = global.get('gemelo') || {};\ng.prediccion = g.prediccion || {};\ng.prediccion[field] = { valor: data.valor, horizon_min: data.horizon_min, actualizado: new Date().toISOString() };\nglobal.set('gemelo', g);\nreturn null;",
        "outputs": 0,
