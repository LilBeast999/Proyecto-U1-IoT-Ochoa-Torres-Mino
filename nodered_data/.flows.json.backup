    {
        "id": "d2e41f13fc10f35f",
        "type": "function",
        "z": "cba3b38867a78e6d",
        "name": "Formato CSV",
        "func": "let fecha = new Date().toLocaleString(\"es-CL\");\n\nlet estado = \"normal\";\nif (msg.payload.temperatura > 24 || msg.payload.humedad > 70) {\n    estado = \"alerta\";\n}\n\nmsg.payload = {\n    timestamp: fecha,\n    temperatura: msg.payload.temperatura,\n    humedad: msg.payload.humedad,\n    gas: msg.payload.gas,\n    estado_alerta: estado\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 1260,
        "wires": [
            [
                "3bf649e629ca8364"
            ]
        ]
    },
